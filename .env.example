# Copy this file to ".env" and fill in your real values.
# Never commit the actual ".env" file — it's already in .gitignore.

# Django
SECRET_KEY=replace-with-a-long-random-string

# Stripe (test keys, from https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_TEST_SECRET_KEY=your_stripe_secret_key_here

# ipinfo.io (from https://ipinfo.io/account/token)
IPINFO_ACCESS_TOKEN=your_ipinfo_token_here

# Only needed if you switch to djecommerce/settings/production.py
DEBUG=False
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
STRIPE_LIVE_PUBLIC_KEY=
STRIPE_LIVE_SECRET_KEY=
